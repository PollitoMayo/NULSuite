{
  "name": "nul-suite",
  "private": true,
  "scripts": {
    "dev:bot": "pnpm --filter @nul/bot dev",
    "dev:server": "pnpm --filter @nul/server dev",
    "dev:desktop": "pnpm --filter @nul/desktop dev",
    "build": "pnpm --filter @nul/shared build && pnpm --parallel --filter !@nul/shared build",
    "start:bot": "pnpm build && pnpm --filter @nul/bot start",
    "start:server": "pnpm build && pnpm --filter @nul/server start",
    "start": "pnpm build && pnpm --filter @nul/bot start & pnpm --filter @nul/server start",
    "deploy:commands": "pnpm --filter @nul/bot deploy:commands"
  }
}
